generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(uuid())
  name      String?
  email     String?   @unique
  password  String?   
  googleId  String?   @unique
  googleRefreshToken String?
  githubToken String?
  githubUsername String?
  avatarUrl String?
  timezone  String?   
  deletedAt DateTime? 

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notifications        Notification[]
  hostedMeetings       Meeting[]             @relation("MeetingHost")
  meetingParticipants  MeetingParticipant[]
  hostedSchedules      MeetingSchedule[]     @relation("ScheduleHost")
  scheduleParticipants ScheduleParticipant[]
  editorProjects       EditorProject[]

  @@index([email])
  @@index([googleId])
  @@map("users")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  message   String
  metadata  Json?           
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt(sort: Desc)])
  @@map("notifications")
}


model MeetingSchedule {
  id             String    @id @default(uuid())
  hostId         String
  title          String
  description    String?
  startTime      DateTime
  endTime        DateTime?
  isRecurring    Boolean   @default(false)
  recurrenceRule String?   
  timezone       String?  

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  host         User                  @relation("ScheduleHost", fields: [hostId], references: [id], onDelete: Cascade)
  participants ScheduleParticipant[]
  meetings     Meeting[]

  @@index([hostId])
  @@index([startTime])
  @@map("meeting_schedules")
}

model ScheduleParticipant {
  id            String      @id @default(uuid())
  scheduleId    String
  userId        String
  googleRefreshToken String?
  googleEventId String?
  role          MeetingRole @default(PARTICIPANT)

  schedule      MeetingSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([scheduleId, userId])
  @@index([scheduleId])
  @@index([userId])
  @@map("schedule_participants")
}

model Meeting {
  id         String  @id @default(uuid())
  roomId     String  @unique 
  scheduleId String?
  passcode   String? 
  userId     String
  isHost     Boolean @default(false)
  roomName   String?
  isEnded    Boolean @default(false)
  endedAt    DateTime?

  recordingState      RecordingState @default(IDLE)
  recordingStartedAt  DateTime?
  recordingStoppedAt  DateTime?
  processingStartedAt DateTime?
  processingEndedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user           User              @relation("MeetingHost", fields: [userId], references: [id], onDelete: Cascade)
  schedule       MeetingSchedule?  @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  participants   MeetingParticipant[]
  rawChunks      MediaChunk[]
  finalRecording FinalRecording?
  editorProjects EditorProject[]

  @@index([userId])
  @@index([scheduleId])
  @@index([recordingState])
  @@map("meetings")
}

model MeetingParticipant {
  id        String      @id @default(uuid())
  meetingId String
  userId    String
  role      MeetingRole @default(PARTICIPANT)
  joinedAt  DateTime    @default(now())
  leftAt    DateTime?

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([meetingId])
  @@index([userId])
  @@index([meetingId, userId])
  @@map("meeting_participants")
}

model MediaChunk {
  id             String            @id @default(uuid())
  meetingId      String
  bucketLink     String
  mimeType       String?
  uploaderUserId String?
  sequenceNumber Int?
  durationMs     Int?
  startedAt      DateTime?
  createdAt      DateTime          @default(now())
  status         ChunkUploadStatus @default(UPLOADED)

  meeting        Meeting           @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@unique([meetingId, uploaderUserId, sequenceNumber])
  @@index([meetingId, status])
  @@index([uploaderUserId])
  @@map("media_chunks")
}

model FinalRecording {
  id              String          @id @default(uuid())
  meetingId       String          @unique
  videoLink       String
  audioLink       String?
  visibleToEmails String[]        @default([])
  generatedAt     DateTime        @default(now())

  meeting         Meeting         @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  editorProjects  EditorProject[] 

  @@map("final_recordings")
}

model EditorProject {
  id               String        @id @default(uuid())
  ownerId          String
  meetingId        String
  finalRecordingId String?       
  sourceMode       SourceMode
  status           ProjectStatus @default(DRAFT)
  durationMs       Int?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  fps              Int           @default(30)
  width            Int           @default(1280)
  height           Int           @default(720)

  owner            User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  meeting          Meeting       @relation(fields: [meetingId], references: [id])
  finalRecording   FinalRecording? @relation(fields: [finalRecordingId], references: [id])

  tracks   EditorTrack[]
  overlays EditorOverlay[]
  assets   EditorAsset[]
  exports  ExportJob[]

  @@index([ownerId])
  @@index([meetingId])
  @@index([finalRecordingId])
  @@index([status])
  @@map("editor_projects")
}

model EditorTrack {
  id        String      @id @default(uuid())
  projectId String
  type      TrackType
  order     Int
  visible   Boolean     @default(true)
  muted     Boolean     @default(false)
  volume    Float?      @default(1.0)

  project   EditorProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  clips     EditorClip[]

  @@unique([projectId, order])
  @@index([projectId])
  @@map("editor_tracks")
}

model EditorClip {
  id              String      @id @default(uuid())
  trackId         String
  sourceAssetId   String
  sourceStartMs   Int
  timelineStartMs Int
  durationMs      Int
  name            String?
  metadata        Json?       

  track           EditorTrack @relation(fields: [trackId], references: [id], onDelete: Cascade)
  asset           EditorAsset @relation(fields: [sourceAssetId], references: [id])

  @@index([trackId])
  @@index([sourceAssetId])
  @@map("editor_clips")
}

model EditorOverlay {
  id              String        @id @default(uuid())
  projectId       String
  type            OverlayType
  content         Json
  timelineStartMs Int
  durationMs      Int
  transform       Json
  style           Json
  zIndex          Int @default(0)

  project         EditorProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("editor_overlays")
}

model EditorAsset {
  id            String        @id @default(uuid())
  projectId     String
  meetingId     String        
  participantId String?
  assetType     AssetType
  url           String
  waveformUrl   String?
  thumbUrl      String?
  durationMs    Int?

  project       EditorProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  clips         EditorClip[] 

  @@index([projectId])
  @@index([meetingId])
  @@index([participantId])
  @@map("editor_assets")
}

model ExportJob {
  id        String       @id @default(uuid())
  projectId String
  status    ExportStatus @default(QUEUED)
  outputUrl String?
  progress  Int          @default(0)
  error     String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt  

  project   EditorProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("export_jobs")
}


enum MeetingRole {
  HOST
  CO_HOST
  PARTICIPANT
}

enum SourceMode {
  FINAL      
  MULTITRACK 
}

enum ProjectStatus {
  DRAFT      
  READY      
  EXPORTING  
  COMPLETED  
  FAILED     
}

enum TrackType {
  VIDEO
  AUDIO
  TEXT 
}

enum OverlayType {
  TEXT
  IMAGE
  LOWER_THIRD
  SHAPE
}

enum AssetType {
  VIDEO
  AUDIO
}

enum ExportStatus {
  QUEUED
  PROCESSING
  DONE
  FAILED
}

enum RecordingState {
  IDLE
  RECORDING
  UPLOADING
  PROCESSING
  READY
  FAILED
}

enum ChunkUploadStatus {
  UPLOADED  
  PROCESSING
  MERGED    
  FAILED
}

enum NotificationType {
  MEETING_INVITE
  MEETING_REMINDER
  RECORDING_REQUEST
  RECORDING_REQUEST_APPROVED
  RECORDING_REQUEST_DENIED
  RECORDING_READY
  RECORDING_FAILED
  OTHER
}